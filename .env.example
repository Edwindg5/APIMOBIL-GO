# Server Configuration
PORT=8080
ENVIRONMENT=development

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=kajve_user
DB_PASSWORD=kajve_secure_password
DB_NAME=kajve_db
DB_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRATION_HOURS=1
JWT_REFRESH_EXPIRATION_HOURS=720

# CORS
# Lista de origenes permitidos, separados por comas (sin espacios necesarios, se recortan automaticamente)
CORS_ALLOWED_ORIGINS=http://localhost:4200,http://movil-kajve.dnc-ed-denz.shop,https://movil-kajve.dnc-ed-denz.shop,http://dnc-ed-denz.shop,https://dnc-ed-denz.shop

# API Configuration
API_WEB_URL=http://api-web:3001
MQTT_BROKER_URL=mqtt://mosquitto:1883
MQTT_USERNAME=kajve
MQTT_PASSWORD=kajve_password

# Rate Limiting
RATE_LIMIT_REQ_PER_MIN=100
# Rafaga maxima de requests simultaneas por IP antes de exigir espaciado
# (golang.org/x/time/rate: "burst"). Con burst bajo, varias pantallas de la
# app pidiendo datos en paralelo devuelven 429 aunque RATE_LIMIT_REQ_PER_MIN
# sea alto.
RATE_LIMIT_BURST=20

# Lotes reclamados por QR
# id_usuario del usuario placeholder (sin-asignar@kajve.internal) creado por api-web.
# Requerido: el servidor no arranca si falta. Confirmar el valor real contra la BD (10 en produccion).
PLACEHOLDER_LOTE_USER_ID=10

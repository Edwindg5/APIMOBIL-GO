# Server Configuration
PORT=8080
ENVIRONMENT=development

# Database PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=kajve_user
DB_PASSWORD=kajve_secure_password
DB_NAME=kajve_db
DB_SSL_MODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production_min_32_chars
JWT_EXPIRATION_HOURS=24
JWT_REFRESH_EXPIRATION_HOURS=720

# CORS
CORS_ALLOWED_ORIGIN=http://localhost:3000,https://yourdomain.com

# API Configuration
API_WEB_URL=http://api-web:3001
MQTT_BROKER_URL=mqtt://mosquitto:1883
MQTT_USERNAME=kajve
MQTT_PASSWORD=kajve_password

# Rate Limiting
RATE_LIMIT_REQ_PER_MIN=100

{
  "info": {
    "_postman_id": "kajve-api-mobile",
    "name": "Kajve API Mobile",
    "description": "Colección de endpoints para API Mobile de Kajve",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"productor@kajve.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/login",
              "host": ["{{base_url}}"],
              "path": ["auth", "login"]
            }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/auth/refresh",
              "host": ["{{base_url}}"],
              "path": ["auth", "refresh"]
            }
          }
        }
      ]
    },
    {
      "name": "Lotes",
      "item": [
        {
          "name": "List Lotes",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/lotes",
              "host": ["{{base_url}}"],
              "path": ["lotes"]
            }
          }
        },
        {
          "name": "Get Lote",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/lotes/1",
              "host": ["{{base_url}}"],
              "path": ["lotes", "1"]
            }
          }
        },
        {
          "name": "Create Lote",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nombre\": \"Lote Prueba\",\n  \"descripcion\": \"Lote de prueba para testing\",\n  \"area\": 100.5\n}"
            },
            "url": {
              "raw": "{{base_url}}/lotes",
              "host": ["{{base_url}}"],
              "path": ["lotes"]
            }
          }
        }
      ]
    },
    {
      "name": "Lecturas",
      "item": [
        {
          "name": "Get Lecturas",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/lotes/1/lecturas?limit=50",
              "host": ["{{base_url}}"],
              "path": ["lotes", "1", "lecturas"],
              "query": [
                {
                  "key": "limit",
                  "value": "50"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Alertas",
      "item": [
        {
          "name": "Get Alertas",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/lotes/1/alertas",
              "host": ["{{base_url}}"],
              "path": ["lotes", "1", "alertas"]
            }
          }
        }
      ]
    },
    {
      "name": "Dispositivos",
      "item": [
        {
          "name": "Link Device",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"esp32_id\": \"ESP32-TEST-001\",\n  \"provisioning_token\": \"token_de_prueba\",\n  \"lote_name\": \"Lote Test\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/devices/link",
              "host": ["{{base_url}}"],
              "path": ["devices", "link"]
            }
          }
        }
      ]
    },
    {
      "name": "Reportes",
      "item": [
        {
          "name": "Request Reporte",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{access_token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"lote_id\": 1,\n  \"tipo\": \"diario\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/reportes",
              "host": ["{{base_url}}"],
              "path": ["reportes"]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8080"
    },
    {
      "key": "access_token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    }
  ]
}
